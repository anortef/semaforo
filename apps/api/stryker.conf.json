{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.unit.config.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.integration.test.ts",
    "!src/index.ts",
    "!src/standalone.ts",
    "!src/test/**",
    "!src/infrastructure/test/**",
    "!src/infrastructure/persistence/**",
    "!src/infrastructure/http/routes/**",
    "src/infrastructure/http/routes/secretRoutes.ts",
    "src/infrastructure/http/routes/publicRoutes.ts",
    "src/infrastructure/http/routes/adminRoutes.ts",
    "!src/infrastructure/http/app.ts",
    "!src/infrastructure/http/swagger.ts",
    "!src/infrastructure/cache/InMemoryRequestCounter.ts",
    "!src/infrastructure/cache/InMemoryToggleCache.ts",
    "!src/infrastructure/cache/RedisToggleCache.ts",
    "!src/infrastructure/cache/SecretCache.ts"
  ],
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": null
  },
  "tempDirName": ".stryker-tmp",
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  }
}
